DATABASE_URL=sqlite:///database.db
APP_HOST=0.0.0.0
APP_PORT=8000
MAX_REQUEST_BODY_BYTES=10485760
UVICORN_TIMEOUT_KEEP_ALIVE_SECONDS=5
UVICORN_LIMIT_CONCURRENCY=100
CORS_ALLOW_ORIGINS=*
CORS_ALLOW_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOW_HEADERS=*
CORS_ALLOW_CREDENTIALS=false
CORS_MAX_AGE=600
CONTENT_TYPE_ALLOWED_TYPES=application/json,application/*+json,application/x-www-form-urlencoded,multipart/form-data
CONTENT_TYPE_BODY_METHODS=POST,PUT,PATCH,DELETE
DOCUMENT_STORAGE_BACKEND=local
DOCUMENT_STORAGE_ROOT=var/uploads
